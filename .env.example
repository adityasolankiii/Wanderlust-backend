
# Database
DB_URL=your_jdbc_url
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=your_jwt_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# PII Encryption
PII_ENCRYPTION_KEY=your_base64_32byte_key

# Email
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password

# OAuth2 (Social Login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# Frontend URL
FRONTEND_URL=your_frontend_url (e.g., http://localhost:5173)
CORS_ALLOWED_ORIGINS=comma_separated_list_of_allowed_origins (e.g., http://localhost:5173,http://localhost:5174,http://localhost:3000)